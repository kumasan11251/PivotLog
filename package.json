{
  "name": "pivot-log",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "web": "expo start --web",
    "dev:all": "concurrently -n ios,android -c blue,green \"npm run ios\" \"npm run android\"",
    "dev:all:device": "concurrently -n ios,android,device -c blue,green,yellow \"npm run ios\" \"npm run android\" \"npm run ios:device\"",
    "dev:sim": "concurrently -n ios,android -c blue,green \"npm run ios\" \"npm run android\"",
    "sync:google-services": "cp google-services.json android/app/google-services.json && echo 'google-services.json synced to android/app/'",
    "prebuild": "npm run sync:google-services && expo prebuild",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix"
  },
  "dependencies": {
    "@bacons/apple-targets": "^3.0.7",
    "@expo-google-fonts/noto-sans-jp": "^0.4.2",
    "@expo/prebuild-config": "^54.0.8",
    "@expo/vector-icons": "^15.0.3",
    "@invertase/react-native-apple-authentication": "^2.5.0",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-firebase/app": "^23.5.0",
    "@react-native-firebase/auth": "^23.5.0",
    "@react-native-firebase/firestore": "^23.5.0",
    "@react-native-firebase/functions": "^23.5.0",
    "@react-native-google-signin/google-signin": "^16.0.0",
    "@react-native-picker/picker": "2.11.1",
    "@react-navigation/native": "^7.1.21",
    "@react-navigation/native-stack": "^7.7.0",
    "expo": "~54.0.25",
    "expo-build-properties": "~1.0.9",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.20",
    "expo-device": "~8.0.10",
    "expo-font": "~14.0.9",
    "expo-haptics": "~15.0.7",
    "expo-intent-launcher": "~13.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-notifications": "~0.32.16",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.15",
    "fs-extra": "^11.3.3",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.12.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.47.0",
    "@typescript-eslint/parser": "^8.47.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
