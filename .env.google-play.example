# Google Play Console monthly reports
#
# Copy these values into a local ignored env file, for example:
#   cp .env.google-play.example .env.google-play.local
#
# Then run:
#   set -a; source .env.google-play.local; set +a
#
# In Play Console, add the service account under Users and permissions with
# access to the target app and permission to view/download reports. Keep the
# JSON key outside git. This repo ignores google-service-account.json as a
# safety net.

GOOGLE_PLAY_PACKAGE_NAME=com.kumasan11251.pivotlog
GOOGLE_PLAY_REPORTS_BUCKET=pubsite_prod_rev_00000000000000000000
GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH=/absolute/path/to/google-service-account.json

# Alternative to GOOGLE_PLAY_SERVICE_ACCOUNT_KEY_PATH if needed:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/google-service-account.json
# GOOGLE_PLAY_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"..."}'
