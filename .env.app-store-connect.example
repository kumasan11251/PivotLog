# App Store Connect API
#
# Copy these values into a local ignored env file, for example:
#   cp .env.app-store-connect.example .env.app-store-connect.local
#
# Then run:
#   set -a; source .env.app-store-connect.local; set +a
#
# Keep the .p8 file outside git. This repo ignores *.p8 as a safety net.

ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000
ASC_KEY_ID=ABC123DEFG
ASC_APP_ID=1476097583
ASC_PRIVATE_KEY_PATH=/absolute/path/to/AuthKey_ABC123DEFG.p8

# Alternative to ASC_PRIVATE_KEY_PATH if needed:
# ASC_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
