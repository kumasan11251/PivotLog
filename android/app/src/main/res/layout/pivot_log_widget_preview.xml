<?xml version="1.0" encoding="utf-8"?>
<!-- プレビュー専用レイアウト: ウィジェット追加画面で表示されるサンプルデータ入りの静的レイアウト -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background_light">

    <!-- 日付ヘッダー行（日付 + 日記記入状態） -->
    <LinearLayout
        android:id="@+id/date_header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="2dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/date_header_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="2月4日(火)"
            android:textSize="10sp"
            android:textColor="@color/widget_text_secondary"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/diary_status_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✔"
            android:textSize="10sp"
            android:textColor="@color/widget_text_secondary"
            android:includeFontPadding="false" />

        <TextView
            android:id="@+id/streak_emoji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔥"
            android:textSize="11sp"
            android:layout_marginStart="6dp"
            android:includeFontPadding="false"
            android:visibility="visible" />

        <TextView
            android:id="@+id/streak_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15日連続"
            android:textSize="11sp"
            android:textColor="@color/widget_text_secondary"
            android:layout_marginStart="2dp"
            android:includeFontPadding="false"
            android:visibility="visible" />

    </LinearLayout>

    <!-- 上部: 残り時間と進捗率を横並び -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <!-- 左側: 残り時間（年と日を横並び） -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:baselineAligned="true">

            <!-- 残り年数（数字） -->
            <TextView
                android:id="@+id/remaining_years_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="46"
                android:textSize="32sp"
                android:textColor="@color/widget_primary"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium" />

            <!-- 年ラベル -->
            <TextView
                android:id="@+id/remaining_years_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="年"
                android:textSize="14sp"
                android:textColor="@color/widget_text_primary"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="8dp"
                android:includeFontPadding="false" />

            <!-- 残り日数（数字） -->
            <TextView
                android:id="@+id/remaining_days_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10"
                android:textSize="24sp"
                android:textColor="@color/widget_primary"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium" />

            <!-- 日ラベル -->
            <TextView
                android:id="@+id/remaining_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日"
                android:textSize="12sp"
                android:textColor="@color/widget_text_primary"
                android:layout_marginStart="1dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 右側: 進捗率 -->
        <TextView
            android:id="@+id/life_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="42%"
            android:textSize="18sp"
            android:textColor="@color/widget_primary"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- プログレスバー -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="1000"
        android:progress="425"
        android:progressDrawable="@drawable/progress_bar_drawable"
        android:progressBackgroundTint="@color/widget_progress_background"
        android:progressTint="@color/widget_primary"
        android:layout_marginTop="10dp" />

    <!-- カスタムテキスト（左揃え、残りスペースを使用） -->
    <TextView
        android:id="@+id/custom_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="あと46回の桜を見届けられる"
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:maxLines="20"
        android:ellipsize="end"
        android:layout_marginTop="10dp"
        android:gravity="start|center_vertical"
        android:lineSpacingExtra="2dp"
        android:visibility="visible" />

    <!-- 後方互換性のための非表示ビュー -->
    <TextView
        android:id="@+id/remaining_years"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/remaining_days"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
