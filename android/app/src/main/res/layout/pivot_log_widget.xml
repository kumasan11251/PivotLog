<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background_light">

    <!-- 上部ヘッダー: 日付 + ストリーク -->
    <LinearLayout
        android:id="@+id/header_row"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <!-- 日付ラベル -->
        <TextView
            android:id="@+id/date_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/widget_text_secondary"
            android:includeFontPadding="false" />

        <!-- 日記状態インジケーター -->
        <TextView
            android:id="@+id/diary_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:includeFontPadding="false"
            android:layout_marginEnd="6dp"
            android:visibility="gone" />

        <!-- ストリーク表示 -->
        <TextView
            android:id="@+id/streak_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="11sp"
            android:textColor="@color/widget_text_secondary"
            android:includeFontPadding="false"
            android:visibility="gone" />

    </LinearLayout>

    <!-- カウントダウン表示 + 進捗率 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom">

        <!-- 左側: 残り時間 -->
        <LinearLayout
            android:id="@+id/countdown_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:baselineAligned="true">

            <!-- 残り年数（数字） -->
            <TextView
                android:id="@+id/remaining_years_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="32sp"
                android:textColor="@color/widget_primary"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium" />

            <!-- 年ラベル -->
            <TextView
                android:id="@+id/remaining_years_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="年"
                android:textSize="14sp"
                android:textColor="@color/widget_text_primary"
                android:layout_marginStart="1dp"
                android:layout_marginEnd="8dp"
                android:includeFontPadding="false" />

            <!-- 残り日数（数字） -->
            <TextView
                android:id="@+id/remaining_days_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="24sp"
                android:textColor="@color/widget_primary"
                android:textStyle="bold"
                android:includeFontPadding="false"
                android:fontFamily="sans-serif-medium" />

            <!-- 日ラベル -->
            <TextView
                android:id="@+id/remaining_days_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="日"
                android:textSize="12sp"
                android:textColor="@color/widget_text_primary"
                android:layout_marginStart="1dp"
                android:includeFontPadding="false" />

        </LinearLayout>

        <!-- 右側: 進捗率 -->
        <TextView
            android:id="@+id/life_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="--%"
            android:textSize="18sp"
            android:textColor="@color/widget_primary"
            android:textStyle="bold"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium" />

    </LinearLayout>

    <!-- プログレスバー -->
    <ProgressBar
        android:id="@+id/progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="6dp"
        android:max="1000"
        android:progress="0"
        android:progressDrawable="@drawable/progress_bar_drawable"
        android:layout_marginTop="8dp" />

    <!-- メッセージテキスト -->
    <TextView
        android:id="@+id/custom_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text=""
        android:textSize="12sp"
        android:textColor="@color/widget_text_secondary"
        android:ellipsize="end"
        android:layout_marginTop="8dp"
        android:gravity="start|center_vertical"
        android:lineSpacingExtra="2dp"
        android:visibility="gone" />

    <!-- 後方互換性のための非表示ビュー -->
    <TextView
        android:id="@+id/remaining_years"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/remaining_days"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone" />

</LinearLayout>
