<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/widget_background">

    <!-- タイトル -->
    <TextView
        android:id="@+id/widget_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="人生の進捗"
        android:textSize="12sp"
        android:textColor="#666666" />

    <!-- 進捗パーセント -->
    <TextView
        android:id="@+id/widget_progress_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="42.5%"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#8B9D83"
        android:layout_marginTop="4dp" />

    <!-- プログレスバー -->
    <ProgressBar
        android:id="@+id/widget_progress_bar"
        style="@android:style/Widget.ProgressBar.Horizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="8dp"
        android:max="100"
        android:progress="42"
        android:progressDrawable="@drawable/widget_progress_bar" />

    <!-- 残り時間 -->
    <TextView
        android:id="@+id/widget_remaining_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="残り 37年 6ヶ月"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginTop="8dp" />

    <!-- カスタムテキスト -->
    <TextView
        android:id="@+id/widget_custom_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="11sp"
        android:textColor="#666666"
        android:textStyle="italic"
        android:maxLines="2"
        android:ellipsize="end"
        android:layout_marginTop="4dp"
        android:visibility="gone" />

</LinearLayout>
